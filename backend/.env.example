# Backend Environment Variables
# Copy this file to .env and fill in your values

# MongoDB Connection (MongoDB Atlas free tier recommended)
MONGO_URL=mongodb+srv://username:password@cluster.mongodb.net/?retryWrites=true&w=majority
DB_NAME=docuflow_ai

# Google Gemini API Key (free at aistudio.google.com)
GEMINI_API_KEY=your-gemini-api-key-here

# CORS Origins (comma-separated, use your Vercel URL in production)
CORS_ORIGINS=http://localhost:3000,https://your-app.vercel.app

# Frontend Environment Variables (create frontend/.env)
REACT_APP_API_URL=http://localhost:8000/api
# In production, replace with your Render backend URL:
# REACT_APP_API_URL=https://your-backend.onrender.com/api
